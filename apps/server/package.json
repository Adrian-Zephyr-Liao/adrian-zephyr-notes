{
  "name": "@adrian-zephyr-notes/server",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "scripts": {
    "build": "nest build",
    "format": "vp fmt . --write",
    "dev": "nest start --watch",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma.config.ts",
    "langgraph:checkpoint:setup": "ts-node --esm scripts/setup-langgraph-checkpoints.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "vp lint .",
    "test": "vp test src",
    "typecheck": "tsc --noEmit --pretty false",
    "test:watch": "vp test src --watch",
    "test:cov": "vp test src --coverage",
    "test:debug": "vp test src --inspect",
    "test:e2e": "vp test --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@adrian-zephyr-notes/contracts": "workspace:*",
    "@ag-ui/client": "0.0.57",
    "@copilotkit/runtime": "1.62.2",
    "@langchain/core": "1.2.1",
    "@langchain/langgraph": "1.4.7",
    "@langchain/langgraph-checkpoint-postgres": "1.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
