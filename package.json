{
  "name": "adrian-zephyr-notes",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' dev",
    "dev:admin": "pnpm --filter @adrian-zephyr-notes/admin dev",
    "dev:website": "pnpm --filter @adrian-zephyr-notes/website dev",
    "dev:server": "pnpm --filter @adrian-zephyr-notes/server dev",
    "db:generate": "pnpm --filter @adrian-zephyr-notes/server prisma:generate",
    "db:migrate": "pnpm --filter @adrian-zephyr-notes/server prisma:migrate",
    "db:deploy": "pnpm --filter @adrian-zephyr-notes/server prisma:deploy",
    "build": "pnpm -r --filter './apps/*' build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "format": "vp fmt . --write --disable-nested-config",
    "format:check": "vp fmt . --check --disable-nested-config",
    "lint": "vp lint .",
    "prepare": "husky",
    "test": "pnpm -r --filter './apps/*' test",
    "typecheck": "pnpm --filter @adrian-zephyr-notes/contracts typecheck && pnpm --filter @adrian-zephyr-notes/markdown typecheck && pnpm --filter @adrian-zephyr-notes/admin exec tsc --noEmit --pretty false && pnpm --filter @adrian-zephyr-notes/website typecheck && pnpm --filter @adrian-zephyr-notes/server typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "husky": "^9.1.7",
    "typescript": "6.0.3",
    "vite-plus": "0.2.1",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@10.13.1"
}
