# DNS must point both hosts to the ECS public IP before first deployment.
# Keep both hosts under the same registrable domain, for example:
# notes.example.com and admin.example.com.
WEBSITE_HOST=notes.example.com
ADMIN_HOST=admin.example.com
# Share login cookies between WEBSITE_HOST and ADMIN_HOST. Use the shared parent
# domain, for example .example.com.
SESSION_COOKIE_DOMAIN=.example.com
ACME_EMAIL=admin@example.com

# Alibaba Cloud ECS in mainland China usually builds faster with npmmirror.
# Set to https://registry.npmjs.org if you prefer the official npm registry.
PNPM_REGISTRY=https://registry.npmmirror.com

POSTGRES_DB=adrian_zephyr_notes
POSTGRES_USER=adrian
# Use only URL-safe characters because the password is embedded in DATABASE_URL.
# Generate one with:
# openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 48; echo
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Comma-separated GitHub logins allowed into the admin console.
ADMIN_GITHUB_LOGINS=Adrian-Zephyr-Liao

# Configure the GitHub OAuth app callback URL as:
# https://notes.example.com/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=replace-with-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-client-secret

# Optional. Required only when AI summary/admin-agent features are used.
LLM_API_KEY=
LLM_PROVIDER=minimax
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M3
LLM_TIMEOUT_MS=60000

LANGGRAPH_CHECKPOINT_SCHEMA=public
LANGGRAPH_CHECKPOINT_SETUP_ON_START=false
